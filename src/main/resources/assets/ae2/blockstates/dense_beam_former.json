{
  "multipart": [
    { "when": { "facing": "down", "state": "off" }, "apply": { "model": "ae2:dense_beam_former_off", "x": 90 } },
    { "when": { "facing": "down", "state": "has_channel" }, "apply": { "model": "ae2:dense_beam_former_on", "x": 90 } },
    { "when": { "facing": "up", "state": "off" }, "apply": { "model": "ae2:dense_beam_former_off", "x": 270 } },
    { "when": { "facing": "up", "state": "has_channel" }, "apply": { "model": "ae2:dense_beam_former_on", "x": 270 } },
    { "when": { "facing": "north", "state": "off" }, "apply": { "model": "ae2:dense_beam_former_off" } },
    { "when": { "facing": "north", "state": "has_channel" }, "apply": { "model": "ae2:dense_beam_former_on" } },
    { "when": { "facing": "south", "state": "off" }, "apply": { "model": "ae2:dense_beam_former_off", "y": 180 } },
    { "when": { "facing": "south", "state": "has_channel" }, "apply": { "model": "ae2:dense_beam_former_on", "y": 180 } },
    { "when": { "facing": "west", "state": "off" }, "apply": { "model": "ae2:dense_beam_former_off", "y": 270 } },
    { "when": { "facing": "west", "state": "has_channel" }, "apply": { "model": "ae2:dense_beam_former_on", "y": 270 } },
    { "when": { "facing": "east", "state": "off" }, "apply": { "model": "ae2:dense_beam_former_off", "y": 90 } },
    { "when": { "facing": "east", "state": "has_channel" }, "apply": { "model": "ae2:dense_beam_former_on", "y": 90 } }
  ]
}